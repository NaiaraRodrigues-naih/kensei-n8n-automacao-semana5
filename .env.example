# Copie este arquivo para .env e preencha com suas chaves REAIS
# O arquivo .env NUNCA deve ser commitado no git

# OpenAI
OPENAI_API_KEY=sk-proj-SUACHAVE_AQUI

# Google Sheets (ID da planilha — da URL entre /d/ e /edit)
GOOGLE_SHEET_ID=SEU_ID_DA_PLANILHA_AQUI

# Telegram (Projeto 2 - Notificador de Site Down)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF_SEU_TOKEN_AQUI
TELEGRAM_CHAT_ID=SEU_CHAT_ID_AQUI

# Email (Projeto 3 - Threat Intel Diario)
EMAIL_DESTINO=seuemail@gmail.com

# Projeto Pessoal - Monitor Email Vazado (haveibeenpwned.com/API/Key)
HIBP_API_KEY=SUA_CHAVE_HIBP_AQUI

# Projeto 4 - API Pessoal com Webhook
WEBHOOK_URL=http://localhost:5678/webhook/sentiment

# n8n (se rodar localmente via Docker ou npm)
N8N_ENCRYPTION_KEY=CHAVE_DE_CRIPTOGRAFIA_DO_N8N
